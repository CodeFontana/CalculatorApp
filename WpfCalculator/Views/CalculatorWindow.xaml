<Window x:Class="WpfCalculator.Views.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfCalculator.Views"
        xmlns:vm="clr-namespace:WpfCalculator.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:CalculatorViewModel, IsDesignTimeCreatable=True}"
        Title="Calculator"
        Height="600"
        Width="400">

    <!--
        Note: ButtonCommand.CanExecuteChanged routes through CommandManager.RequerySuggested,
        so Command/CommandParameter attribute order is not significant here. See:
        https://stackoverflow.com/questions/335849/wpf-commandparameter-is-null-first-time-canexecute-is-called
    -->

    <Grid Background="#212529">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>

        <!-- Calculator Display -->

        <!--
            The display text renders at its natural font size (see DisplayStyle) when it fits the
            cell. When the content grows wider than the cell, the Viewbox scales the text down
            uniformly (StretchDirection="DownOnly" prevents scaling up past the natural size).
        -->
        <Viewbox Grid.Column="0"
                 Grid.Row="0"
                 Grid.ColumnSpan="4"
                 Margin="10 0"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Stretch="Uniform"
                 StretchDirection="DownOnly">
            <TextBlock x:Name="Result"
                       Text="{Binding ResultDisplay, Mode=OneWay}"
                       Style="{StaticResource DisplayStyle}" />
        </Viewbox>

        <!-- First Button Row -->

        <Button x:Name="AcButton"
                Grid.Column="0"
                Grid.Row="1"
                Content="AC"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource SpecialStyle}" />

        <Button x:Name="NegButton"
                Grid.Column="1"
                Grid.Row="1"
                Content="+/-"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource SpecialStyle}" />

        <Button x:Name="PercentageButton"
                Grid.Column="2"
                Grid.Row="1"
                Content="%"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource SpecialStyle}" />

        <Button x:Name="DivButton"
                Grid.Column="3"
                Grid.Row="1"
                Content="/"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource OperatorStyle}" />

        <!-- Second Button Row -->

        <Button x:Name="SevenButton"
                Grid.Column="0"
                Grid.Row="2"
                Content="7"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="EightButton"
                Grid.Column="1"
                Grid.Row="2"
                Content="8"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="NineButton"
                Grid.Column="2"
                Grid.Row="2"
                Content="9"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="MultButton"
                Grid.Column="3"
                Grid.Row="2"
                Content="x"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource OperatorStyle}" />

        <!-- Third Button Row -->

        <Button x:Name="FourButton"
                Grid.Column="0"
                Grid.Row="3"
                Content="4"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="FiveButton"
                Grid.Column="1"
                Grid.Row="3"
                Content="5"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="SixButton"
                Grid.Column="2"
                Grid.Row="3"
                Content="6"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="MinusButton"
                Grid.Column="3"
                Grid.Row="3"
                Content="-"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource OperatorStyle}" />

        <!-- Fourth Button Row -->

        <Button x:Name="OneButton"
                Grid.Column="0"
                Grid.Row="4"
                Content="1"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="TwoButton"
                Grid.Column="1"
                Grid.Row="4"
                Content="2"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="ThreeButton"
                Grid.Column="2"
                Grid.Row="4"
                Content="3"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="PlusButton"
                Grid.Column="3"
                Grid.Row="4"
                Content="+"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource OperatorStyle}" />

        <!-- Fifth Button Row -->

        <Button x:Name="ZeroButton"
                Grid.Column="0"
                Grid.Row="5"
                Grid.ColumnSpan="2"
                Content="0"
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="DecButton"
                Grid.Column="2"
                Grid.Row="5"
                Content="."
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource DigitStyle}" />

        <Button x:Name="EqualButton"
                Grid.Column="3"
                Grid.Row="5"
                Content="="
                Command="{Binding CalculatorCommand}"
                CommandParameter="{Binding Content, RelativeSource={RelativeSource Self}}"
                Style="{StaticResource OperatorStyle}" />

    </Grid>
</Window>
